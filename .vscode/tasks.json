{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compilar e Rodar C",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "mkdir -p output && gcc \"${file}\" -o \"output/${fileBasenameNoExtension}\" -lm && \"./output/${fileBasenameNoExtension}\""
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        }
    ]
}